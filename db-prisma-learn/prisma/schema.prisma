generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  Post  Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String  @db.VarChar(255)
  content   String?
  author_id Int?
  User      User?   @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
