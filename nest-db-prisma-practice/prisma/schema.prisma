generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String  @db.VarChar(255)
  content   String?
  author_id Int?
  User      User?   @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([title])
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  Post  Post[]
}

model Book {
  id            String    @id @default(uuid())
  title         String
  author        String
  publishedYear Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publisherId   String    @default("6c25a6ed-7f1b-4690-8ef7-674a98f2fe72")
  publisher     Publisher @relation(fields: [publisherId], references: [id])

  @@unique([title, author, publishedYear])
}

model Publisher {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book[]
}

model Member {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
